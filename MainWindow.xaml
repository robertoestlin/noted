<Window x:Class="Noted.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Noted" Height="700" Width="1100" MinWidth="600" MinHeight="300"
        Icon="logo/logo.png"
        Closing="Window_Closing"
        Closed="Window_Closed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="TodoPanelColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="TodoPanelBorder"
                Grid.Row="1"
                Grid.Column="0"
                Visibility="Collapsed"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,1,0"
                Background="#FAFAFA"
                Focusable="True"
                FocusVisualStyle="{x:Null}"
                PreviewKeyDown="TodoPanelBorder_PreviewKeyDown"
                MouseDown="TodoPanelBorder_MouseDown">
            <DockPanel Margin="10">
                <TextBlock x:Name="TodoPanelTitleText"
                           DockPanel.Dock="Top"
                           Text="Task Panel"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="TodoAreaComboBox"
                              Grid.Column="0"
                              MinWidth="110"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              ToolTip="Select area"
                              SelectionChanged="TodoAreaComboBox_SelectionChanged"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="TodoAddTodayButton"
                                Content="+"
                                Width="30"
                                Height="30"
                                Margin="0,0,6,0"
                                FontWeight="SemiBold"
                                ToolTip="Add task to first group"
                                Click="TodoAddTodayButton_Click"/>
                        <Button x:Name="TodoCompletedToggleButton"
                                Content="✓"
                                Width="30"
                                Height="30"
                                FontWeight="SemiBold"
                                ToolTip="Recently Completed"
                                Click="TodoCompletedToggleButton_Click"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TodoGroupsContainer"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="0" Grid.ColumnSpan="2">
            <Border DockPanel.Dock="Left" Padding="6,2,4,2" VerticalAlignment="Center">
                <Image Source="logo/logo.png" Width="24" Height="24" Stretch="Uniform"/>
            </Border>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="_File">
                    <MenuItem x:Name="MenuItemNewTab" Header="_New" InputGestureText="Ctrl+N / Ctrl+T" Click="MenuNew_Click"/>
                    <Separator/>
                    <MenuItem Header="_Open file" Click="MenuOpenFile_Click"/>
                    <Separator/>
                    <MenuItem Header="Export to file..." Click="MenuExportToFile_Click"/>
                    <MenuItem Header="Copy file content">
                        <MenuItem Header="Copy without assignees" Click="MenuCopyFileContentWithoutAssignees_Click"/>
                        <MenuItem Header="Copy with assignees" Click="MenuCopyFileContentWithAssignees_Click"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Open Last Backup in Code" Click="MenuOpenLastBackup_Click"/>
                    <Separator/>
                    <MenuItem Header="_Reopen Closed Tab" InputGestureText="Ctrl+Shift+T" Click="MenuReopenClosedTab_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MenuItemCloseTab" Header="_Close Tab" InputGestureText="Ctrl+W" Click="MenuCloseTab_Click"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Click="MenuExit_Click"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="MenuUndo_Click"/>
                    <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="MenuRedo_Click"/>
                    <Separator/>
                    <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Click="MenuCut_Click"/>
                    <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Click="MenuCopy_Click"/>
                    <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Click="MenuPaste_Click"/>
                    <Separator/>
                    <MenuItem Header="_Find + Replace..." InputGestureText="Ctrl+F / Ctrl+H" Click="MenuFindReplace_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MenuItemGoToLine" Header="_Go To Line..." InputGestureText="Ctrl+G" Click="MenuGoToLine_Click"/>
                    <MenuItem x:Name="MenuItemGoToTab" Header="Go To _Tab..." InputGestureText="Ctrl+P" Click="MenuGoToTab_Click"/>
                    <MenuItem x:Name="MenuItemTrimTrailingEmptyLines" Header="Trim _Trailing Empty Lines" InputGestureText="Ctrl+Shift+Space" Click="MenuTrimTrailingEmptyLines_Click"/>
                    <Separator/>
                    <MenuItem Header="Selection _Actions">
                        <MenuItem x:Name="MenuItemCopySelectionTo"
                                  Header="_Copy Selection To"
                                  SubmenuOpened="MenuCopySelectionTo_SubmenuOpened">
                            <MenuItem Header="(Loading...)" IsEnabled="False"/>
                        </MenuItem>
                        <MenuItem x:Name="MenuItemMoveSelectionTo"
                                  Header="_Move Selection To"
                                  SubmenuOpened="MenuMoveSelectionTo_SubmenuOpened">
                            <MenuItem Header="(Loading...)" IsEnabled="False"/>
                        </MenuItem>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem x:Name="MenuItemWrapLongLinesVisually"
                              Header="_Split Lines Visually"
                              IsCheckable="True"
                              Click="MenuWrapLongLinesVisually_Click"/>
                    <MenuItem x:Name="MenuItemStyledBullets"
                              Header="Render _Bullet Symbols"
                              IsCheckable="True"
                              Click="MenuStyledBullets_Click"/>
                    <MenuItem x:Name="MenuItemShowSmileys"
                              Header="Render _Smileys"
                              IsCheckable="True"
                              Click="MenuShowSmileys_Click"/>
                    <MenuItem x:Name="MenuItemRenderStyledTags"
                              Header="Styled _Tags"
                              IsCheckable="True"
                              Click="MenuRenderStyledTags_Click"/>
                    <MenuItem x:Name="MenuItemShowLineAssignments"
                              Header="Show line _assignments"
                              IsCheckable="True"
                              Click="MenuShowLineAssignments_Click"/>
                    <MenuItem x:Name="MenuItemShowHorizontalRuler"
                              Header="Render Horizontal _Dividers"
                              IsCheckable="True"
                              Click="MenuShowHorizontalRuler_Click"/>
                    <MenuItem x:Name="MenuItemShowInlineImages"
                              Header="Render Inline _Images"
                              IsCheckable="True"
                              Click="MenuShowInlineImages_Click"/>
                </MenuItem>
                <MenuItem Header="_Tools">
                    <MenuItem Header="_Settings" Click="MenuSettings_Click"/>
                    <MenuItem Header="_Tags" Click="MenuTags_Click"/>
                    <MenuItem Header="_Users" Click="MenuUsers_Click"/>
                    <MenuItem Header="Tab _Cleanup" Click="MenuTabCleanup_Click"/>
                    <MenuItem Header="_Recover Tabs" Click="MenuRecoverTabs_Click"/>
                </MenuItem>
                <MenuItem Header="_Plugins">
                    <MenuItem Header="_Alarms" Click="MenuAlarms_Click"/>
                    <MenuItem Header="_Base64" Click="MenuBase64_Click"/>
                    <MenuItem Header="Computer _Statistics" Click="MenuComputerStatistics_Click"/>
                    <MenuItem Header="JS_ON Pretty" Click="MenuJsonPretty_Click"/>
                    <MenuItem Header="_JWT Decoder" Click="MenuJwtDecoder_Click"/>
                    <MenuItem Header="_Message Overlay" InputGestureText="Ctrl+O" Click="MenuQuickMessageOverlay_Click"/>
                    <MenuItem x:Name="MenuItemMidiPlayer" Header="M_IDI Player" InputGestureText="Ctrl+M" Click="MenuMidiPlayer_Click"/>
                    <MenuItem Header="Mon_goDB">
                        <MenuItem Header="MongoDB API Get _Token" Click="MenuMongoDbApiGetToken_Click"/>
                        <MenuItem Header="ObjectId to _Timestamp Converter" Click="MenuMongoObjectIdTimestampConverter_Click"/>
                        <MenuItem Header="_SRV DNS Lookup" Click="MenuMongoSrvLookup_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Network">
                        <MenuItem Header="_CIDR Converter" Click="MenuCidrConverter_Click"/>
                        <MenuItem Header="_TXT DNS Lookup" Click="MenuTxtLookup_Click"/>
                    </MenuItem>
                    <MenuItem Header="Pass_word Generator" Click="MenuPasswordGenerator_Click"/>
                    <MenuItem Header="_Programming">
                        <MenuItem Header="_Project Line Counter" Click="MenuProjectLineCounter_Click"/>
                    </MenuItem>
                    <MenuItem Header="Safe _Paste Area" Click="MenuSafePasteArea_Click"/>
                    <MenuItem Header="_Seach Files" Click="MenuSearchFiles_Click"/>
                    <MenuItem Header="Stan_dup" Click="MenuStandup_Click"/>
                    <MenuItem Header="Task _Panel" InputGestureText="F3" Click="MenuTodoList_Click"/>
                    <MenuItem Header="Te_xt">
                        <MenuItem Header="Text _Splitter" Click="MenuTextSplitter_Click"/>
                    </MenuItem>
                    <MenuItem Header="Time _Converter" Click="MenuTimeConverter_Click"/>
                    <MenuItem Header="_Time Reporter" Click="MenuTimeReport_Click"/>
                </MenuItem>
                <MenuItem Header="_About">
                    <MenuItem Header="_Info" Click="MenuAboutInfo_Click"/>
                </MenuItem>
            </Menu>
        </DockPanel>

        <DockPanel Grid.Row="1" Grid.Column="1">
        <!-- Status bar -->
            <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
                <StatusBarItem>
                    <TextBlock x:Name="StatusLine" Text="Ln 1" MinWidth="50"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="StatusColumn" Text="Col 1" MinWidth="50"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="StatusBullets" Text="B 0"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="StatusUnsavedDot" Text=""/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="StatusAutoSave" Text="" Foreground="#555"/>
                </StatusBarItem>
                <Separator x:Name="StatusAlarmSnoozeSeparator"/>
                <StatusBarItem x:Name="StatusAlarmSnoozeItem">
                    <TextBlock x:Name="StatusAlarmSnooze" Text="" Foreground="#555"/>
                </StatusBarItem>
            </StatusBar>

        <!-- Tab control -->
            <TabControl x:Name="MainTabControl"
                        SelectionChanged="MainTabControl_SelectionChanged"
                        Background="White"/>
        </DockPanel>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,8,4"
                    IsHitTestVisible="False">
            <TextBlock x:Name="MidiPlayerDockedIndicator"
                       Text="MIDI Player: Docked  |"
                       Margin="0,0,8,0"
                       Foreground="#666"
                       FontSize="11"
                       Visibility="Collapsed"/>
            <TextBlock Text="0.11.3"
                       Foreground="#666"
                       FontSize="11"/>
        </StackPanel>

        <Border x:Name="MessageOverlay"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Panel.ZIndex="99"
                Background="#D9111827"
                MouseDown="MessageOverlay_DismissByMouseDown"
                PreviewKeyDown="MessageOverlay_DismissByKeyDown"
                Focusable="True">
            <Grid>
                <Canvas x:Name="MessageOverlayEffectCanvas"
                        IsHitTestVisible="False"
                        ClipToBounds="True"/>
                <Viewbox Stretch="Uniform" StretchDirection="Both" Margin="30">
                    <TextBlock x:Name="MessageOverlayText"
                               Text="GG"
                               Foreground="#62E5FF"
                               FontWeight="Black"
                               FontFamily="Segoe UI Black, Segoe UI, Arial"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Viewbox>
                <Border x:Name="MessageOverlayCountdownContainer"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,32,56"
                        Padding="18,8,18,8"
                        CornerRadius="14"
                        Background="#33000000"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageOverlayCountdown"
                               Text="00:00"
                               FontSize="36"
                               Foreground="#62E5FF"
                               FontWeight="Bold"
                               FontFamily="Segoe UI, Segoe UI Variable, Arial"/>
                </Border>
                <Border x:Name="MessageOverlayNowPlayingContainer"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="32,0,0,56"
                        Padding="18,10,18,12"
                        CornerRadius="14"
                        Background="#33000000"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        Width="600"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="MessageOverlayNowPlayingLabel"
                                   Text="NOW PLAYING"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#5FD4FF"/>
                        <TextBlock x:Name="MessageOverlayNowPlayingPlaylist"
                                   Text=""
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#7FE0FF"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="MessageOverlayNowPlayingTitle"
                                   Text=""
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="MessageOverlayNowPlayingMeta"
                                   Text=""
                                   FontSize="13"
                                   Foreground="#A9B9D8"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <Border x:Name="MessageOverlayHelpContainer"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,32,32,0"
                        Padding="18,12,18,12"
                        CornerRadius="14"
                        Background="#33000000"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="SHORTCUTS"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#5FD4FF"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"  Grid.Column="0" Text="H"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="0"  Grid.Column="1" Text="Toggle this help panel"                                                   Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="1"  Grid.Column="0" Text="Up / Down"   FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="1"  Grid.Column="1" Text="Cycle text color"                                                         Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="2"  Grid.Column="0" Text="Left / Right" FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"    Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="2"  Grid.Column="1" Text="Cycle saved messages"                                                     Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="3"  Grid.Column="0" Text="B"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="3"  Grid.Column="1" Text="Toggle blinking"                                                          Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="4"  Grid.Column="0" Text="T"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="4"  Grid.Column="1" Text="Toggle blink type (whole / sweep)"                                         Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="5"  Grid.Column="0" Text="E"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="5"  Grid.Column="1" Text="Cycle effect (Snowy / Rainy / Off)"                                          Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="6"  Grid.Column="0" Text="R"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="6"  Grid.Column="1" Text="Reset countdown"                                                          Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="7"  Grid.Column="0" Text="M"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="7"  Grid.Column="1" Text="Pause / play music"                                                       Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="8"  Grid.Column="0" Text="N"           FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="8"  Grid.Column="1" Text="Next track"                                                               Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="9"  Grid.Column="0" Text="Esc"         FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="9"  Grid.Column="1" Text="Close overlay"                                                            Foreground="#C1CFEA" Margin="0,1,0,1"/>
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Other"       FontFamily="Consolas, Courier New" FontWeight="Bold" Foreground="White"     Margin="0,1,16,1"/>
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="Any other key closes the overlay"                                         Foreground="#C1CFEA" Margin="0,1,0,1"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
